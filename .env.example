# Copy to .env and fill in secrets (never commit .env).

# Chat agent — OpenRouter (openrouter.ai/keys)
# Use OPENROUTER_API_KEY, not OPENAI_API_KEY (sk-or- keys are OpenRouter, not OpenAI).
OPENROUTER_API_KEY=sk-or-...
INVENTORY_AGENT_MODEL=openrouter:deepseek/deepseek-v4-flash

# Alternatives:
# DEEPSEEK_API_KEY=sk-...
# INVENTORY_AGENT_MODEL=deepseek:deepseek-v4-flash
# GOOGLE_API_KEY=
# INVENTORY_AGENT_MODEL=google:gemini-2.5-flash-lite
# OPENAI_API_KEY=sk-...
# INVENTORY_AGENT_MODEL=openai:gpt-4o-mini

# Local secrets — copy this file to `.env` and fill in your values.
#   cp .env.example .env
#
# `.env` is gitignored. Never commit real API keys.
#
# Only the chat agent reads these variables (via docker-compose `env_file`).
# Database, PowerSync, and Django settings are in docker-compose.yml — you do
# not need to configure those here.
#
# Without a valid key, the rest of the app works (login, dashboard, orders)
# but chat messages will fail with an authentication error.

# --- OpenRouter (recommended) ---
# 1. Sign up at https://openrouter.ai/
# 2. Create a key at https://openrouter.ai/keys (starts with sk-or-)
# 3. Paste it below — use OPENROUTER_API_KEY, not OPENAI_API_KEY
OPENROUTER_API_KEY=sk-or-...
INVENTORY_AGENT_MODEL=openrouter:openai/gpt-4o

# --- Alternatives (uncomment one provider + matching model) ---
# DEEPSEEK_API_KEY=sk-...
# INVENTORY_AGENT_MODEL=deepseek:deepseek-v4-flash
# GOOGLE_API_KEY=
# INVENTORY_AGENT_MODEL=google:gemini-2.5-flash-lite
# OPENAI_API_KEY=sk-...
# INVENTORY_AGENT_MODEL=openai:gpt-4o
